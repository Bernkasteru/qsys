QSYS_TEST_MODE=0

QSYS_ENV=prod
QSYS_PORT=8080
QSYS_SIM_PORT=9100

QSYS_MYSQL_DSN=root:root@tcp(localhost:3306)/conorder_db?charset=utf8mb4&parseTime=True&loc=Local&interpolateParams=true&transaction_isolation='READ-COMMITTED'
# QSYS_MYSQL_TABLE=orders
QSYS_REDIS_ADDR=localhost:6379
# QSYS_REDIS_AC_KEY=qsys:active_clients

# Kafka 参数
QSYS_KAFKA_BROKERS=localhost:9092,localhost:9094,localhost:9096  # Kafka 3 brokers 地址
QSYS_KAFKA_TOPIC=conorder
# QSYS_KAFKA_GROUP_ID
QSYS_KAFKA_WORKER_NUM=100
QSYS_KAFKA_MAX_QUEUE_SIZE=2100
QSYS_KAFKA_SEND_TIMEOUT=3s
QSYS_KAFKA_BATCH_SIZE=200
QSYS_KAFKA_BATCH_TIMEOUT=60ms